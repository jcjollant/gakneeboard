#!/bin/sh

# Fix Cypress path issues when Git is run from VS Code
unset ELECTRON_RUN_AS_NODE

# Get repo root from script location (server/.husky/pre-push)
SCRIPT_DIR=$(dirname "$0")
REPO_ROOT=$(cd "$SCRIPT_DIR/../../" && pwd)

echo ">>> [Pre-Push] Starting checks..."

echo ">>> [Shared] Running tests..."
cd "$REPO_ROOT/shared" || exit 1
npm test || exit 1

echo ">>> [Server] Running tests..."
cd "$REPO_ROOT/server" || exit 1
npm test || exit 1
npx tsc --noEmit || exit 1

echo ">>> [UI] Running tests..."
cd "$REPO_ROOT/ui" || exit 1
npm test || exit 1

echo ">>> [UI] Running layout snapshot tests..."
npm run test:snapshots || exit 1

echo ">>> [Pre-Push] All checks passed!"
exit 0
